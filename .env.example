# ─────────────────────────────────────────────────────────────────────────────
# Millésime Coffee Bot — variables d'environnement
# Copiez ce fichier en `.env` et remplissez les VRAIES valeurs.
# NE COMMIT JAMAIS le fichier `.env` (gitignored).
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram Bot (obligatoire) ─────────────────────────────────────────────
BOT_TOKEN=put_your_bot_token_here
BOT_PASSWORD=choose_a_strong_password
OWNER_CHAT_ID=your_telegram_user_or_group_id
OWNER_USER_ID=your_personal_telegram_user_id
# Username Telegram du vendeur (sans @) — pour le bouton "Nous contacter"
# du suivi de commande. Si vide, repli sur un deep-link vers OWNER_USER_ID.
SUPPORT_USERNAME=

# ── Compte personnel admin via Telethon (optionnel) ────────────────────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=

# ── WebApp selfie (un seul à remplir) ──────────────────────────────────────
WEBAPP_URL=
NGROK_AUTH_TOKEN=

# ── Adresse / autocomplétion ───────────────────────────────────────────────
# Si defini : Mapbox (meilleure couverture). Sinon repli automatique sur Photon (OSM, gratuit).
# Token public Mapbox (format pk.xxxxx) — dashboard Mapbox > Access tokens.
MAPBOX_TOKEN=

# ── Stockage persistant ────────────────────────────────────────────────────
# Option A : Supabase
SUPABASE_URL=
SUPABASE_KEY=
# Option B : backup vers repo GitHub privé
GITHUB_TOKEN=
GITHUB_DATA_OWNER=
GITHUB_DATA_REPO=coffee-bot-data
GITHUB_DATA_BRANCH=main
DATA_DIR=

# ── Paiement (optionnels) ──────────────────────────────────────────────────
BANK_IBAN=
PAYMENT_LINK=
CRYPTO_ETH=
CRYPTO_USDT=

# ── Divers ────────────────────────────────────────────────────────────────
PORT=5000
